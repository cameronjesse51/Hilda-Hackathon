# Use the same value for the web/OTP service and the FastAPI service.
# Generate a value with: openssl rand -hex 32
SESSION_SECRET=replace-with-at-least-32-random-characters

# Runtime URL used by the web/OTP service to request UUID-backed sessions.
API_INTERNAL_URL=http://localhost:8000

# Optional developer-only SMS bypass. Keep disabled in public production.
# DEV_AUTH_KEY is entered manually in the UI and is never bundled by Vite.
ENABLE_DEV_AUTH=false
DEV_AUTH_KEY=replace-with-at-least-24-random-characters
DEV_AUTH_PHONE=+18015551234
VITE_ENABLE_DEV_AUTH=false
